/* --- Root Variables (Colors) --- */
:root {
    /* --- Mica Inspired Color Variables --- */
    --background-color: rgba(12, 13, 14, 0.7);
    --foreground-color: rgb(237, 238, 240);
    --accent-color: #0078d4;
    --border-color: rgb(53, 59, 69);
    --icon-color: rgb(169, 174, 184);
    --icon-hover: rgba(169, 174, 184, 0.8);
    --hover-color: rgba(93, 114, 135, 0.12);
    --active-color: rgb(93, 114, 135);
    --inactive-color: rgba(93, 114, 135, 0.5);
}

/* --- Base Styles --- */
* {
    font-size: 12px;
    color: var(--foreground-color);
    font-weight: 600;
    font-family: "Segoe UI", "JetBrainsMono NFP";
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* --- Yasb Bar Itself --- */
.yasb-bar {
    background-color: transparent !important;
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
}

.container-left,
.container-center,
.container-right {
    background-color: var(--background-color);
    border-radius: 16px;
    padding: 0;
    margin: 0 4px;
}

.container-right,
.container-left {
    background-color: var(--background-color);
}

.container-center {
    background-color: transparent;
}


/* --- Individual Widgets --- */
.widget {
    padding: 0 12px;
    margin: 0;
}

.container-right .widget .icon:hover {
    color: var(--icon-hover);
}

/* --- Icons --- */
.icon {
    font-size: 14px;
    color: var(--icon-color);
}

/* --- Widget Labels --- */
.widget .label {
    padding: 0px 2px;
}

/* --- Apps Widget Specific --- */
.apps-widget {
    padding: 0 4p 0 2px;
}

.apps-widget .widget-container .label {
    font-size: 12px;
}

/* --- Komorebi Active Layout --- */
.komorebi-active-layout {
    padding: 0 4px;
}

.komorebi-active-layout .label {
    font-weight: 600;
    padding-bottom: 2px;
}

/* --- Workspace and Layout Containers --- */
.apps-widget .widget-container,
.komorebi-workspaces .widget-container,
.komorebi-active-layout .widget-container,
.glazewm-workspaces .widget-container,
.glazewm-tiling-direction .widget-container {
    background-color: var(--background-color);
    border-radius: 11px;
    margin: 5px 0;
    padding: 0px 5px 0px 5px;
    border: 1px solid var(--border-color);
}

/* --- Komorebi & GlazeWM Workspaces --- */
.komorebi-workspaces,
.glazewm-workspaces {
    padding: 0;
}

.komorebi-workspaces .offline-status,
.glazewm-workspaces .offline-status {
    color: var(--foreground-color);
    font-size: 12px;
    padding: 0 4px;
    font-weight: 600;
}

.komorebi-workspaces .ws-btn,
.glazewm-workspaces .ws-btn {
    color: transparent;
    width: 10px;
    height: 10px;
    background-color: var(--active-color);
    border-radius: 5px;
    margin: 0 2px;
    font-size: 1px;
}

.komorebi-workspaces .ws-btn:hover,
.glazewm-workspaces .ws-btn:hover {
    color: var(--accent-color);
    background-color: var(--hover-color);
}

.komorebi-workspaces .ws-btn.populated,
.glazewm-workspaces .ws-btn.populated {
    width: 10px;
    height: 10px;
    background-color: var(--active-color);
    border-radius: 5px;
    margin: 0 2px;
    font-size: 1px;
}

.komorebi-workspaces .ws-btn.active,
.glazewm-workspaces .ws-btn.active_populated,
.glazewm-workspaces .ws-btn.active_empty {
    color: transparent;
    background-color: var(--icon-color);
    width: 36px;
    height: 10px;
    border-radius: 5px;
}

/* --- Glazewm Tiling Direction --- */
.glazewm-tiling-direction {
    background-color: transparent;
    padding: 0;
    margin: 4px 0;
}

.glazewm-tiling-direction .btn {
    font-size: 14px;
    width: 14px;
    padding: 0 4px 0 12px;
    color: var(--foreground-color);
    border: none;
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 0 2px;
}

.glazewm-tiling-direction .btn:hover {
    background-color: var(--hover-color);
}

/* --- Apps Widget Label --- */
.apps-widget .label {
    font-size: 14px;
    padding: 0 2px;
    color: var(--foreground-color);
}

/* --- Uptime Widget --- */
.uptime {
    font-size: 14px;
    margin-bottom: 10px;
    color: var(--foreground-color);
    font-weight: 600;
}

/* --- Power Menu Widget --- */
.power-menu-widget .label {
    font-size: 13px;
}

/* --- Power Menu Popup --- */
.power-menu-popup {
    background-color: rgba(20, 13, 14, 0.9);
    border-radius: 6px;
    padding: 10px;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
}

.power-menu-popup .button {
    padding: 0;
    width: 180px;
    height: 230px;
    border-radius: 8px;
    background-color: rgba(255, 255, 255, 0.08);
    color: var(--foreground-color);
    border-left: 4px solid rgba(0, 0, 0, 0.05);
    border-right: 4px solid rgba(0, 0, 0, 0.05);
    border-top: 8px solid rgba(0, 0, 0, 0.05);
    border-bottom: 8px solid rgba(0, 0, 0, 0.05);
    margin: 0px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
}

.power-menu-popup .button:hover {
    background-color: rgba(255, 255, 255, 0.12);
    border-left: 4px solid rgba(0, 0, 0, 0.1);
    border-right: 4px solid rgba(0, 0, 0, 0.1);
    border-top: 8px solid rgba(0, 0, 0, 0.1);
    border-bottom: 8px solid rgba(0, 0, 0, 0.1);
}

.power-menu-popup .button .label {
    margin-bottom: 8px;
    font-size: 16px;
    font-weight: 500;
    color: var(--accent-color);
}

.power-menu-popup .button .icon {
    font-size: 64px;
    padding-top: 32px;
    color: var(--foreground-color);
}

.power-menu-popup .button.cancel .icon {
    padding: 0;
    margin: 0;
}

.power-menu-popup .button.cancel .label {
    color: var(--foreground-color);
    margin: 0;
}

.power-menu-popup .button.cancel {
    height: 32px;
    border-radius: 4px;
}

/* --- Volume Widget --- */
.volume-widget .icon {
    color: var(--foreground-color);
    margin: 1px 2px 0 0;
}

/* --- Battery Widget --- */
.battery-widget .icon {
    margin-right: 6px;
    color: var(--foreground-color);
}

/* --- Brightness Widget --- */
.brightness-widget {
    margin-right: -10px;
}

.brightness-widget .icon {
    color: var(--foreground-color);
}

/* --- Common Widget Padding --- */
.weather-widget,
.battery-widget,
.wifi-widget,
.volume-widget,
.brightness-widget {
    padding: 0 6px;
}

/* --- Weather Widget --- */
.weather-widget .icon {
    font-size: 18px;
    margin: 0 2px 1px 0;
}

/* --- Wallpapers Widget --- */
.wallpapers-widget .icon {
    color: var(--foreground-color);
    font-size: 14px;
    margin: 0;
}

/* --- Taskbar Widget --- */
.taskbar-widget {
    padding: 0;
    margin: 0;
    border: none;
}

.taskbar-widget .app-container {
    padding: 0 6px;
    border: none;
    margin: 0;
}

.taskbar-widget .app-container:hover {
    background-color: var(--hover-color);
    border-radius: 3px;
}

.taskbar-widget .app-container .app-title {
    padding-left: 4px;
}

/* --- Whkd Widget --- */
.whkd-widget {
    padding: 0 6px 0 6px;
}

.whkd-widget .icon {
    font-size: 14px;
    color: var(--foreground-color);
}

/* --- Wallpapers Gallery Window --- */
.wallpapers-gallery-window {
    background-color: rgba(20, 13, 14, 0.9);
    border: 0;
    margin: 0;
    border-radius: 8px;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
}

.wallpapers-gallery-buttons {
    background-color: rgba(255, 255, 255, 0.08);
    color: var(--foreground-color);
    border: none;
    font-size: 14px;
    padding: 8px 0;
    border-radius: 8px;
    margin: 0 8px 8px 8px;
    width: 600px;
}

.wallpapers-gallery-buttons:hover {
    background-color: rgba(255, 255, 255, 0.12);
}

.wallpapers-gallery-image {
    border: 4px solid transparent;
    border-radius: 10px;
}

.wallpapers-gallery-image:hover {
    border: 4px solid var(--accent-color);
}

.wallpapers-gallery-image.focused {
    border: 4px solid var(--accent-color);
}

/* --- Systray --- */
.systray {
    border: none;
    margin-right: -12px;
    display: flex;
    align-items: center;
}

.systray .unpinned-container {
    border-radius: 8px;
    padding: 2px;
}

.systray .pinned-container {
    background: transparent;
    padding: 2px;
}

.systray .button {
    margin: 0 2px;
    color: var(--foreground-color);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 3px;
}

.systray .button:hover {
    background: var(--hover-color);
}

.systray .unpinned-visibility-btn {
    border-radius: 4px;
    font-size: 20px;
}

/* --- Common Styles --- */
.wifi-widget,
.brightness-widget,
.systray {
    margin-top: 2.4px;
}

/* --- AI Chat Specifics --- */
.ai-chat-widget {
    padding: 0 4px;
}

.ai-chat-popup {
    background-color: var(--background-color);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 0;
    min-width: 450px;
    max-width: 450px;
    min-height: 600px;
    max-height: 600px;
}

.ai-chat-popup.floating {
    border: 2px solid var(--accent-color);
    min-width: 900px;
    max-width: 900px;
    min-height: 700px;
    max-height: 700px;
}

.ai-chat-popup .chat-header {
    background-color: rgba(0, 0, 0, 0.2);
    padding: 12px;
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    border-bottom: 1px solid var(--border-color);
}

.ai-chat-popup .chat-header .loader-line {
    color: var(--accent-color);
}

.ai-chat-popup .chat-header .float-button,
.ai-chat-popup .chat-header .close-button {
    background-color: transparent;
    border: none;
    color: var(--foreground-color);
    font-size: 16px;
    padding: 4px 8px;
    border-radius: 6px;
}

.ai-chat-popup .chat-header .float-button:hover,
.ai-chat-popup .chat-header .close-button:hover {
    background-color: var(--hover-color);
}

.ai-chat-popup .chat-footer {
    background-color: rgba(0, 0, 0, 0.2);
    padding: 14px;
    border-bottom-left-radius: 12px;
    border-bottom-right-radius: 12px;
    border-top: 1px solid var(--border-color);
}

.ai-chat-popup .chat-header .provider-button,
.ai-chat-popup .chat-header .model-button {
    font-family: "Segoe UI";
    background-color: var(--inactive-color);
    border: 1px solid var(--border-color);
    font-size: 13px;
    color: var(--foreground-color);
    margin-right: 8px;
    border-radius: 6px;
    padding: 6px 12px;
}

.ai-chat-popup .chat-header .provider-button:hover,
.ai-chat-popup .chat-header .model-button:hover {
    background-color: var(--hover-color);
}

.ai-chat-popup .chat-content {
    background-color: transparent;
    border: none;
}

.ai-chat-popup .chat-content .empty-chat .greeting {
    color: var(--foreground-color);
    font-size: 32px;
    font-weight: 600;
}

.ai-chat-popup .chat-content .empty-chat .message {
    color: var(--icon-color);
    font-size: 18px;
    padding-top: 8px;
}

.ai-chat-popup .chat-content .user-message,
.ai-chat-popup .chat-content .assistant-message {
    padding: 12px 14px;
    border-radius: 12px;
    margin: 8px 12px;
}

.ai-chat-popup .chat-content .user-message .text,
.ai-chat-popup .chat-content .assistant-message .text {
    font-size: 14px;
    color: var(--foreground-color);
}

.ai-chat-popup .chat-content .user-message {
    background-color: var(--accent-color);
    margin-left: 40px;
}

.ai-chat-popup .chat-content .assistant-message {
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-color);
    margin-right: 40px;
}

.ai-chat-popup .chat-content .assistant-icon {
    font-size: 20px;
    color: var(--icon-color);
    margin-right: 12px;
}

.ai-chat-popup .chat-footer .chat-input-wrapper {
    background-color: rgba(0, 0, 0, 0.3);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    min-height: 40px;
    max-height: 120px;
    padding: 6px;
}

.ai-chat-popup .chat-footer .chat-input {
    font-size: 14px;
    color: var(--foreground-color);
    border: none;
}

.ai-chat-popup .chat-footer .chat-input-wrapper.focused {
    border-color: var(--accent-color);
}

.ai-chat-popup .chat-footer .clear-button,
.ai-chat-popup .chat-footer .send-button,
.ai-chat-popup .chat-footer .stop-button,
.ai-chat-popup .chat-footer .attach-button {
    color: var(--foreground-color);
    font-size: 16px;
    min-width: 32px;
    max-width: 32px;
    min-height: 32px;
    max-height: 32px;
    border-radius: 6px;
    border: none;
    background: transparent;
}

.ai-chat-popup .chat-footer .stop-button {
    background-color: var(--accent-color);
    color: #ff5c5c;

}

.ai-chat-popup .chat-footer .clear-button:hover {
    color: #ff5c5c;
    background-color: var(--hover-color);
}

.ai-chat-popup .chat-footer .send-button:hover,
.ai-chat-popup .chat-footer .stop-button:hover,
.ai-chat-popup .chat-footer .attach-button:hover {
    background-color: var(--hover-color);
}