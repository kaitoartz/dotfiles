    // =========================================================
    // 4. UI COLORS (Tus colores originales)
    // =========================================================
    "workbench.colorCustomizations": {
    
        "editor.background": "#0E0E12",
        "editor.foreground": "#E6E6EB",
        "editorLineNumber.foreground": "#4B4B57",
        "editorLineNumber.activeForeground": "#9D7CFF",
