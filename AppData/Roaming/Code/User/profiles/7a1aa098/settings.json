        "editorBracketMatch.background": "#00FFC855",
        "editorBracketMatch.border": "#00FFC8"
    },

    // =========================================================
    // 5. SYNTAX COLORS (RESTAURO TUS COLORES, MATO EL ROJO)
    // =========================================================
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": "comment",
                "settings": { "foreground": "#79c85d", "fontStyle": "italic" }
            },
            {
                "scope": "string",
                "settings": { "foreground": "#FF9F43" }
            },
            {
                "scope": "constant.numeric",
                "settings": { "foreground": "#5CFF7A" }
            },
            // CORREGIDO: Keywords (antes rojo) -> Tu azul #4294ff
            {
                "scope": "keyword",
                "settings": { "foreground": "#4294ff" }
            },
            // CORREGIDO: Control (if/else) -> Tu azul #427ecc
            {
                "scope": "keyword.control",
                "settings": { "foreground": "#427ecc" }
            },
            // CORREGIDO: Tipos (antes cyan claro) -> Mantenemos tu cyan #4DE6FF
            {
                "scope": "storage.type",
                "settings": { "foreground": "#4DE6FF" }
            },
            // Clases -> Tu verde #02ddae
            {
                "scope": "entity.name.type",
                "settings": { "foreground": "#02ddae" }
            },
            // CORREGIDO: Métodos (antes rojo) -> Amarillo suave #FFD866
            {
                "scope": "entity.name.function",
                "settings": { "foreground": "#FFD866" }
            },
            {
                "scope": "variable",
                "settings": { "foreground": "#E6E6EB" }
            },
            // Campos Serialized -> Morado #C792EA
            {
                "scope": "variable.other.readwrite",
                "settings": { "foreground": "#C792EA" }
            },
            // CORREGIDO: Atributos [Header] (antes rojo) -> Tu verde #00FFC8
            {
                "scope": "meta.attribute.cs",
                "settings": { "foreground": "#00FFC8" }
            },
            {
                "scope": "identifier.type",
                "settings": { "foreground": "#4DFFFF" }
            },
            {
                "scope": "constant.other.enum",
                "settings": { "foreground": "#FF9F43" }
            },
            {
                "scope": "entity.name.namespace",
                "settings": { "foreground": "#7F7FFF" }
            },
            {
                "scope": "keyword.operator",
                "settings": { "foreground": "#E6E6EB", "fontStyle": "light" }
            },
            
            // === COLORES PARA HTML ===
            // Tags HTML (<div>, <span>, etc.)
            {
                "scope": "entity.name.tag.html",
                "settings": { "foreground": "#4294ff" }  // Azul brillante para tags
            },
            {
                "scope": "punctuation.definition.tag.html",
                "settings": { "foreground": "#427ecc" }  // Azul oscuro para < >
            },
            // Atributos HTML (class, id, src, etc.)
            {
                "scope": "entity.other.attribute-name.html",
                "settings": { "foreground": "#00FFC8" }  // Verde menta para atributos
            },
            {
                "scope": "entity.other.attribute-name.id.html",
                "settings": { "foreground": "#5CFF7A" }  // Verde brillante para id
            },
            {
                "scope": "entity.other.attribute-name.class.html",
                "settings": { "foreground": "#4DE6FF" }  // Cyan para class
            },
            // Valores de atributos HTML
            {
                "scope": "string.quoted.double.html",
                "settings": { "foreground": "#FF9F43" }  // Naranja para strings
            },
            {
                "scope": "string.quoted.single.html",
                "settings": { "foreground": "#FF9F43" }  // Naranja para strings
            },
            // Doctype
            {
                "scope": "meta.tag.metadata.doctype.html",
                "settings": { "foreground": "#7F7FFF" }  // Morado para DOCTYPE
            },
            {
                "scope": "entity.name.tag.doctype.html",
                "settings": { "foreground": "#7F7FFF" }
            },
            // Comentarios HTML (ya está definido para comments en general)
            {
                "scope": "comment.block.html",
                "settings": { "foreground": "#79c85d", "fontStyle": "italic" }
            },
            
            // === COLORES PARA CSS ===
            // Selectores CSS (div, .class, #id, etc.)
            {
                "scope": "entity.name.tag.css",
                "settings": { "foreground": "#4294ff" }  // Azul brillante para tags
            },
            {
                "scope": "entity.other.attribute-name.class.css",
                "settings": { "foreground": "#4DE6FF" }  // Cyan para clases
            },
            {
                "scope": "entity.other.attribute-name.id.css",
                "settings": { "foreground": "#5CFF7A" }  // Verde brillante para IDs
            },
            {
                "scope": "entity.other.attribute-name.pseudo-class.css",
                "settings": { "foreground": "#FFD866" }  // Amarillo para :hover, :active
            },
            {
                "scope": "entity.other.attribute-name.pseudo-element.css",
                "settings": { "foreground": "#FF9F43" }  // Naranja para ::before, ::after
            },
            // Propiedades CSS (color, background, etc.)
            {
                "scope": "support.type.property-name.css",
                "settings": { "foreground": "#00FFC8" }  // Verde menta para propiedades
            },
            {
                "scope": "meta.property-name.css",
                "settings": { "foreground": "#00FFC8" }
            },
            // Valores CSS
            {
                "scope": "support.constant.property-value.css",
                "settings": { "foreground": "#C792EA" }  // Morado para valores predefinidos
            },
            {
                "scope": "constant.numeric.css",
                "settings": { "foreground": "#5CFF7A" }  // Verde para números
            },
            {
                "scope": "keyword.other.unit.css",
                "settings": { "foreground": "#5CFF7A" }  // Verde para unidades (px, em, %)
            },
            // Colores hexadecimales
            {
                "scope": "constant.other.color.rgb-value.hex.css",
                "settings": { "foreground": "#FF9F43" }  // Naranja para colores hex
            },
            // Funciones CSS (rgba, url, calc, etc.)
            {
                "scope": "support.function.css",
                "settings": { "foreground": "#FFD866" }  // Amarillo para funciones
            },
            // At-rules (@media, @import, @keyframes)
            {
                "scope": "keyword.control.at-rule.css",
                "settings": { "foreground": "#7F7FFF" }  // Morado para @rules
            },
            {
                "scope": "keyword.control.at-rule.media.css",
                "settings": { "foreground": "#7F7FFF" }
            },
            // Strings en CSS
            {
                "scope": "string.quoted.double.css",
                "settings": { "foreground": "#FF9F43" }  // Naranja para strings
            },
            {
                "scope": "string.quoted.single.css",
                "settings": { "foreground": "#FF9F43" }
            },
            // Operadores y puntuación CSS
            {
                "scope": "punctuation.definition.entity.css",
                "settings": { "foreground": "#4DE6FF" }  // Cyan para . y #
            },
            {
                "scope": "punctuation.separator.key-value.css",
                "settings": { "foreground": "#E6E6EB" }  // Blanco para :
            },
            // Variables CSS (--variable)
            {
                "scope": "variable.css",
                "settings": { "foreground": "#41d6ff" }  // Cyan eléctrico para variables
            },
            {
                "scope": "variable.argument.css",
                "settings": { "foreground": "#41d6ff" }
            },
            // Important
            {
                "scope": "keyword.other.important.css",
                "settings": { "foreground": "#FF6B9D", "fontStyle": "bold" }  // Rosa para !important
            }
        ]
    },

    "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
            // === TUS COLORES NEÓN (RESTAURADOS) ===
            "keyword.control": "#427ecc",   // Tu azul oscuro
            "keyword": "#4294ff",           // Tu azul brillante
            "modifier": "#4DE6FF",
            "type": "#5fccff",              // Tu celeste
            "method": "#FFD866",            // Amarillo
            "method.declaration": "#FFD866",
            "method.extension": "#4DE6FF",
            "field": "#41d6ff",             // Tu cyan eléctrico
            "variable": "#41d6ff",          // Tu cyan eléctrico
            "property": "#00FFC8",          // Tu verde menta
            "parameter": "#3bbaff",         // Tu azul cielo
            "enum": "#02ddae",              // Tu verde
            "enumMember": "#5CFF7A",
            "namespace": "#7F7FFF",
            "class": "#00FFC8",
            "struct": "#00FFC8",

            // === ELIMINACIÓN DEL ROJO (#FF6AC1) EN SEMANTIC ===
            // Aquí es donde estaba el error, lo cambiamos a tus tonos:
            
            "controlKeyword": "#427ecc",    // Antes rojo -> Ahora tu azul
            "attribute": "#00FFC8",         // Antes rojo -> Ahora tu verde menta
            "operator": "#ffebff"           // Antes rojo -> Ahora blanco/gris
        }
    },
