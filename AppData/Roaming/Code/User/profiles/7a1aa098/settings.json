    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/*.meta": true,
        "**/*.csproj": true,
        "**/*.sln": true,
        "**/Library/": true,
        "**/Temp/": true,
        "**/Obj/": true,
        "**/Build/": true,
        "**/Builds/": true,
        "**/Logs/": true,
        "**/UserSettings/": true
    },
    "unity.autoSave": false,
    "explorer.autoReveal": true,
    "dotnet.excludedPaths": [
        "**/bin/**",
        "**/obj/**",
        "**/Library/**",
        "**/Temp/**"
    ],

